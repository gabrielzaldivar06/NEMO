# AI Memory System Configuration
# Copy this file to .env and customize as needed

# === CORE PATHS ===
# Where all databases and caches will be stored
# Default: ~/.ai_memory (or %USERPROFILE%/.ai_memory on Windows)
# AI_MEMORY_DATA_DIR=/custom/path/to/memory/data

# === EMBEDDING CONFIGURATION ===
# Embedding provider: lm_studio, ollama, or openai
AI_MEMORY_EMBED_PROVIDER=lm_studio

# Model name for embeddings
AI_MEMORY_EMBED_MODEL=nomic-embed-text

# URL for embedding service
AI_MEMORY_EMBED_URL=http://localhost:1234/v1/embeddings

# OpenAI API key (only needed if using OpenAI embeddings)
# OPENAI_API_KEY=your_openai_api_key_here

# === WEATHER CONFIGURATION ===
# Your location coordinates for weather queries
# Default: Motley, MN (46.34, -94.63)
# AI_MEMORY_WEATHER_LAT=46.34
# AI_MEMORY_WEATHER_LON=-94.63
# AI_MEMORY_WEATHER_TZ=America/Chicago

# === MCP SERVER CONFIGURATION ===
# Port for MCP server to listen on
AI_MEMORY_MCP_PORT=1234

# === FILE MONITORING CONFIGURATION ===
# Enable automatic file monitoring for chat platforms
AI_MEMORY_ENABLE_MONITORING=true

# Auto-start file monitoring after 3 minutes (desktop app will control this)
AI_MEMORY_AUTO_START_MONITORING=false

# Custom directories to watch (comma-separated paths)
# AI_MEMORY_WATCH_DIRS=/path/to/custom/chats,/path/to/other/chats

# === DATABASE RETENTION ===
# How long to keep conversation records (days)
AI_MEMORY_CONV_RETENTION_DAYS=90

# How long to keep AI memories (days) 
AI_MEMORY_MEMORY_RETENTION_DAYS=365

# === SEARCH CONFIGURATION ===
# Minimum similarity score for semantic search (0.0 to 1.0)
AI_MEMORY_SIMILARITY_THRESHOLD=0.3

# === LOGGING ===
# Log level: DEBUG, INFO, WARNING, ERROR
AI_MEMORY_LOG_LEVEL=INFO


# =============================================================================
# DOCKER DEPLOYMENT — variables consumed by docker-compose.yml
# =============================================================================
# Only relevant if you are running NEMO via `docker compose up`.
# The plain-Python variables above are ignored inside the container; Docker
# uses the subset below instead.

# Host port to expose NEMO on. Container always listens on 8765 internally.
NEMO_HOST_PORT=8765

# Universal server logging (DEBUG | INFO | WARNING | ERROR).
# nemo_server.py upper-cases this internally so lowercase still works, but the
# documented default matches Python's canonical level names.
LOG_LEVEL=INFO

# --- Embedding backend (default profile) ---
# `custom` routes to the in-process fastembed sidecar at /embed. Override if
# you want NEMO to talk to an external embedding server:
#   custom     — any OpenAI-compatible /v1/embeddings server
#   ollama     — Ollama (auto-set by docker-compose.gpu.yml)
#   lm_studio  — LM Studio running on the host (use host.docker.internal)
#   openai     — OpenAI cloud (requires EMBEDDING_API_KEY)
EMBEDDING_PROVIDER=custom

# Model understood by the provider.
# fastembed catalog: https://qdrant.github.io/fastembed/examples/Supported_Models/
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Leave empty to auto-point at the in-container sidecar.
# Example to hit LM Studio on the host: http://host.docker.internal:1234
EMBEDDING_BASE_URL=

# Only required when EMBEDDING_PROVIDER=openai.
EMBEDDING_API_KEY=

# --- Reranking (off by default) ---
RERANK_ENABLED=false
RERANK_MODEL=
RERANK_BASE_URL=

# --- GPU profile (docker-compose.gpu.yml) ---
OLLAMA_HOST_PORT=11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text