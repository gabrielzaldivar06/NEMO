{
  "name": "nemo-memory",
  "displayName": "NEMO — Memory Observer",
  "description": "Neural Engine Memory Observer — estado del sistema de memoria IA en tiempo real",
  "version": "1.0.0",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nemo-container",
          "title": "NEMO Memory Observer",
          "icon": "media/nemo.svg"
        }
      ]
    },
    "views": {
      "nemo-container": [
        {
          "type": "webview",
          "id": "nemo.statusView",
          "name": "Estado del Sistema"
        }
      ]
    },
    "commands": [
      {
        "command": "nemo.refresh",
        "title": "NEMO: Actualizar Estado",
        "icon": "$(refresh)"
      },
      {
        "command": "nemo.launchDashboard",
        "title": "NEMO: Lanzar Dashboard 3D",
        "icon": "$(graph)"
      },
      {
        "command": "nemo.regenerateDashboard",
        "title": "NEMO: Regenerar Dashboard (sin abrir)",
        "icon": "$(sync)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nemo.launchDashboard",
          "when": "view == nemo.statusView",
          "group": "navigation@1"
        },
        {
          "command": "nemo.regenerateDashboard",
          "when": "view == nemo.statusView",
          "group": "navigation@2"
        },
        {
          "command": "nemo.refresh",
          "when": "view == nemo.statusView",
          "group": "navigation@3"
        }
      ]
    }
  }
}
